# OpenAI API Key (optional)
# The app works with mock AI responses if this is not set
OPENAI_API_KEY=your_openai_api_key_here

# Clerk Authentication (REQUIRED: both keys must be from the SAME Clerk application)
# If you see "infinite redirect" or "keys do not match": copy BOTH keys from one app.
# 1. Go to https://dashboard.clerk.com
# 2. Open ONE application (e.g. your NestWise app)
# 3. Copy BOTH "Publishable key" and "Secret key" from that same app
# 4. Paste them here and restart the dev server. Clear browser cookies for localhost if needed.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Clerk URLs (optional - defaults work for localhost)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/signin
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/signup
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase (optional - for portfolio/watchlist stored in database)
# If not set, the app uses local simulator only (data in browser). Add both to persist to DB.
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Or server-only: SUPABASE_URL=... and SUPABASE_ANON_KEY=...

# Vercel (not needed for basic deployment)
# Vercel auto-detects Next.js projects when you connect your GitHub repo
# No API keys required for standard deployments
