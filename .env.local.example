# OpenAI API Key (optional)
# The app works with mock AI responses if this is not set
OPENAI_API_KEY=your_openai_api_key_here

# Clerk Authentication
# Required for user authentication
# Get these from: https://dashboard.clerk.com
# 1. Create a free account at clerk.com
# 2. Create a new application
# 3. Copy your API keys from the dashboard
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# Clerk URLs (optional - defaults work for localhost)
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/signin
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/signup
# NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
# NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Supabase (optional - for authentication and database)
# Not required for MVP. Only add if you want user accounts and data persistence.
# SUPABASE_URL=your_supabase_project_url
# SUPABASE_ANON_KEY=your_supabase_anon_key

# Vercel (not needed for basic deployment)
# Vercel auto-detects Next.js projects when you connect your GitHub repo
# No API keys required for standard deployments
